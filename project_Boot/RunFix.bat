@echo off
setlocal
cd /d "%~dp0"
set "VIVADO_TCL_FIX_DIR=%~dp0"

echo ========================================================
echo Vivado Original TCL - Complete Flat Project Fix
echo ========================================================
echo.

powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand 
set "RC=%ERRORLEVEL%"

echo.
echo ========================================================
if "%RC%"=="0" (
    echo Finished successfully.
) else (
    echo Failed. Error code: %RC%
)
echo ========================================================
echo.
echo Press any key to close...
pause >nul
exit /b %RC%
